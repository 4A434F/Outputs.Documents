        width: 100%;
        padding: 0cm 8.5mm 0cm 18.5mm; /* top, right, bottom, left */
        font-family: "Arial", sans-serif;
        font-size: 9pt;
        line-height: 1.6;
        color: #000;
        background-color: #fff;
/*         border: 1px solid #000;
            box-shadow: 0 0 6px rgba(0, 0, 0, 0.1);*/
        box-sizing: border-box; 
    }
