@namespace Outputs.Documents.Templates.Documents.Layouts
@using Outputs.Documents.Domain.Locations

<html>
    <head>
        <meta charset="utf-8">
    </head>
    <body class="letter-layout">
        <PostalAddressComponent Address="Address" />
        @ChildContent
    </body>
</html>



@code {
    [Parameter] public PostalAddress? Address { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}

