<style>
    .pdf-footer {
        width: 100%;
        box-sizing: border-box;
        padding: 0mm 10mm 10mm 12mm;
        font-family: Arial, sans-serif;
        color: #000;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 6mm;
    }

    .pdf-footer__left {
        font-size: 5pt;
        line-height: 1.2;
        flex: 1 1 auto;
        min-width: 0;
    }

    .pdf-footer__right {
        font-size: 7pt;
        white-space: nowrap;
        flex: 0 0 auto;
        text-align: right;
        margin-bottom: 5mm;
    }

    .pdf-footer a {
        color: #000;
        text-decoration: none;
    }
</style>

@code {
    [Parameter] public Footer? Model { get; set; }
}