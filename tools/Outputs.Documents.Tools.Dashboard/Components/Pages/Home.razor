@page "/"
@rendermode InteractiveServer
@inject VectorStoreSearchService SearchService
@inject VectorStoreDashboardOptions Options

<PageTitle>Domain Vector Search</PageTitle>

<div class="dashboard-page">
    <section class="page-title-frame">
        <div>
            <p class="eyebrow">Domain Vector Store</p>
            <h2>Search existing domain concepts</h2>
            <p class="page-subtitle">@Options.DatabaseDirectory</p>
        </div>
        <button class="icon-button" type="button" title="Refresh" @onclick="RefreshAsync" disabled="@_isLoading">
            <span class="material-symbols-outlined" aria-hidden="true">refresh</span>
        </button>
    </section>

    <section class="metric-grid" aria-label="Store summary">
        <article class="metric-card">
            <span class="material-symbols-outlined metric-icon" aria-hidden="true">hub</span>
            <div>
                <p class="metric-label">Models</p>
                <strong>@(_overview?.Models.Count ?? 0)</strong>
            </div>
        </article>
        <article class="metric-card">
            <span class="material-symbols-outlined metric-icon" aria-hidden="true">category</span>
            <div>
                <p class="metric-label">Kinds</p>
                <strong>@(_overview?.Kinds.Count ?? 0)</strong>
            </div>
        </article>
        <article class="metric-card">
            <span class="material-symbols-outlined metric-icon" aria-hidden="true">database</span>
            <div>
                <p class="metric-label">Records</p>
                <strong>@(_overview?.RecordCount ?? 0)</strong>
            </div>
        </article>
    </section>

    <section class="search-panel">
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert-panel">
                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                <span>@_error</span>
            </div>
        }

        @if (_overview is null)
        {
            <div class="empty-panel">
                <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
                <p>Loading vector store.</p>
            </div>
        }
        else if (_overview.Models.Count == 0)
        {
            <div class="empty-panel">
                <span class="material-symbols-outlined" aria-hidden="true">database_off</span>
                <p>No vector store models found.</p>
            </div>
        }
        else
        {
            <form class="search-form" @onsubmit="RunSearchAsync" @onsubmit:preventDefault>
                <label>
                    <span>Model</span>
                    <select value="@_selectedModel" @onchange="OnModelChangedAsync" disabled="@_isLoading">
                        @foreach (var model in _overview.Models)
                        {
                            <option value="@model">@model</option>
                        }
                    </select>
                </label>

                <label>
                    <span>Kind</span>
                    <select @bind="_selectedKind" disabled="@_isLoading">
                        <option value="">All</option>
                        @foreach (var kind in _overview.Kinds)
                        {
                            <option value="@kind">@kind</option>
                        }
                    </select>
                </label>

                <label class="query-field">
                    <span>Query</span>
                    <input @bind="_query" placeholder="Name, alias, tag, declaration, or text" disabled="@_isLoading" />
                </label>

                <label>
                    <span>Limit</span>
                    <select @bind="_limit" disabled="@_isLoading">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="25">25</option>
                        <option value="50">50</option>
                    </select>
                </label>

                <button class="primary-button" type="submit" disabled="@(_isLoading || !CanSearch)">
                    <span class="material-symbols-outlined" aria-hidden="true">search</span>
                    <span>Search</span>
                </button>
            </form>
        }
    </section>

    <section class="results-section">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Results</p>
                <h3>@ResultsTitle</h3>
            </div>
            @if (_lastSearchElapsed is not null)
            {
                <span class="result-count">@_lastSearchElapsed.Value.TotalMilliseconds.ToString("0") ms</span>
            }
        </div>

        @if (_hasSearched && _results.Count == 0 && string.IsNullOrWhiteSpace(_error))
        {
            <div class="empty-panel">
                <span class="material-symbols-outlined" aria-hidden="true">search_off</span>
                <p>No matching records.</p>
            </div>
        }
        else if (_results.Count > 0)
        {
            <div class="results-list">
                @foreach (var result in _results)
                {
                    <article class="result-row">
                        <div class="result-row-main">
                            <div class="result-title-line">
                                <h4>@result.Name</h4>
                                <span class="score-chip">@result.Score.ToString("0.###")</span>
                            </div>

                            <div class="result-meta">
                                <span>@result.Kind</span>
                                <span>@result.MatchKind</span>
                                <span>@result.EmbeddingDimensions dimensions</span>
                            </div>

                            <p class="result-text">@result.Text</p>

                            @if (result.Aliases.Count > 0 || result.Tags.Count > 0)
                            {
                                <div class="chip-row">
                                    @foreach (var alias in result.Aliases)
                                    {
                                        <span class="soft-chip">@alias</span>
                                    }
                                    @foreach (var tag in result.Tags)
                                    {
                                        <span class="tag-chip">@tag</span>
                                    }
                                </div>
                            }
                        </div>

                        <dl class="result-details">
                            <div>
                                <dt>Declaration</dt>
                                <dd>@result.Declaration</dd>
                            </div>
                            <div>
                                <dt>Id</dt>
                                <dd>@result.Id</dd>
                            </div>
                        </dl>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="empty-panel quiet">
                <span class="material-symbols-outlined" aria-hidden="true">manage_search</span>
                <p>Ready.</p>
            </div>
        }
    </section>
</div>

@code {
    private VectorStoreOverview? _overview;
    private IReadOnlyList<VectorStoreSearchResultItem> _results = [];
    private string? _selectedModel;
    private string? _selectedKind;
    private string _query = string.Empty;
    private int _limit = 10;
    private bool _isLoading;
    private bool _hasSearched;
    private string? _error;
    private TimeSpan? _lastSearchElapsed;

    private bool CanSearch =>
        _overview?.SelectedModel is not null &&
        !string.IsNullOrWhiteSpace(_query);

    private string ResultsTitle =>
        _hasSearched
            ? $"{_results.Count} matches"
            : "No search yet";

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            _overview = await SearchService.GetOverviewAsync(_selectedModel);
            _selectedModel = _overview.SelectedModel;

            if (_overview.Kinds.All(kind => !string.Equals(kind, _selectedKind, StringComparison.OrdinalIgnoreCase)))
            {
                _selectedKind = null;
            }
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnModelChangedAsync(ChangeEventArgs args)
    {
        _selectedModel = args.Value?.ToString();
        _selectedKind = null;
        _results = [];
        _hasSearched = false;
        _lastSearchElapsed = null;
        await RefreshAsync();
    }

    private async Task RunSearchAsync()
    {
        if (!CanSearch || _selectedModel is null)
        {
            return;
        }

        _isLoading = true;
        _error = null;
        _hasSearched = true;

        var started = DateTimeOffset.UtcNow;

        try
        {
            _results = await SearchService.SearchAsync(
                new VectorStoreSearchRequest(
                    _selectedModel,
                    _query,
                    _selectedKind,
                    _limit));

            _lastSearchElapsed = DateTimeOffset.UtcNow - started;
        }
        catch (Exception exception)
        {
            _results = [];
            _lastSearchElapsed = null;
            _error = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
