@page "/preview/{TemplateKey}"
@page "/preview/{TemplateKey}/{ScenarioKey}"
@page "/preview/{TemplateKey}/{ScenarioKey}/html"
@using Microsoft.AspNetCore.Components
@using Outputs.Documents.Abstractions
@using Outputs.Documents.Preview
@using Outputs.Documents.Preview.Abstractions
@inject IDocumentPreviewCatalog Catalog
@inject IDocumentPreviewHtmlRenderer HtmlRenderer
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(Template?.Name ?? "Template not found")</PageTitle>

@if (Template is null)
{
    <main class="empty-page">
        <h1>Template not found.</h1>
        <p>The URL may be stale or the template key changed.</p>
        <a href="/preview">Back to preview index</a>
    </main>
}
else
{
    <div class="preview-shell">
        <aside class="sidebar">
            <a class="brand" href="/preview">Document Preview</a>
            @foreach (var group in Catalog.Templates.GroupBy(template => template.Group))
            {
                <div class="nav-group">
                    <div class="nav-heading">@group.Key</div>
                    @foreach (var template in group)
                    {
                        var firstScenario = Catalog.GetScenariosForTemplate(template).FirstOrDefault();
                        <a class="nav-link @(template.Key == Template.Key ? "active" : "")"
                           href="@PreviewUrl(template.Key, firstScenario?.Key)">
                            @template.Name
                        </a>
                    }
                </div>
            }
        </aside>

        <main class="preview-main">
            <header class="toolbar">
                <div>
                    <h1>@Template.Name</h1>
                    <p>@Template.ModelType.FullName</p>
                </div>
                <div class="toolbar-controls">
                    <select value="@SelectedScenarioKey" @onchange="OnScenarioChanged" disabled="@(Scenarios.Count == 0)">
                        @foreach (var scenario in Scenarios)
                        {
                            <option value="@scenario.Key">@scenario.Name</option>
                        }
                    </select>
                    <select @bind="Mode">
                        <option value="component">Component</option>
                        <option value="html">Production HTML</option>
                        <option value="raw">Raw HTML</option>
                        <option value="metadata">Metadata</option>
                    </select>
                    <button type="button" @onclick="RefreshAsync">Refresh</button>
                    <button type="button" @onclick="ShowRawHtmlAsync" disabled="@(Scenario is null)">Raw HTML</button>
                </div>
            </header>

            @if (Scenarios.Count == 0)
            {
                <section class="empty-state">
                    <h2>No preview scenarios found for this template.</h2>
                    <p>Add an IDocumentPreviewScenarioProvider for model: @Template.ModelType.Name</p>
                </section>
            }
            else if (Scenario is not null)
            {
                <section class="preview-content">
                    @if (Mode == "component")
                    {
                        <div class="document-canvas">
                            <DynamicComponent Type="Template.BodyTemplateType" Parameters="ComponentParameters" />
                        </div>
                    }
                    else if (Mode == "html")
                    {
                        <iframe class="html-frame" srcdoc="@Html"></iframe>
                    }
                    else if (Mode == "raw")
                    {
                        <pre class="raw-html">@Html</pre>
                    }
                    else
                    {
                        <dl class="metadata">
                            <dt>Template key</dt>
                            <dd>@Template.Key</dd>
                            <dt>Template type</dt>
                            <dd>@Template.BodyTemplateType.FullName</dd>
                            <dt>Model type</dt>
                            <dd>@Template.ModelType.FullName</dd>
                            <dt>Scenario key</dt>
                            <dd>@Scenario.Key</dd>
                            <dt>Scenario name</dt>
                            <dd>@Scenario.Name</dd>
                            <dt>Model parameter</dt>
                            <dd>@Template.ModelParameterName</dd>
                        </dl>
                    }
                </section>
            }
        </main>
    </div>
}

@code {
    [Parameter] public string TemplateKey { get; set; } = string.Empty;

    [Parameter] public string? ScenarioKey { get; set; }

    private DocumentTemplateDescriptor? Template { get; set; }

    private IReadOnlyList<DocumentPreviewScenario> Scenarios { get; set; } = [];

    private DocumentPreviewScenario? Scenario { get; set; }

    private string SelectedScenarioKey => Scenario?.Key ?? string.Empty;

    private string Mode { get; set; } = "component";

    private string Html { get; set; } = string.Empty;

    private Dictionary<string, object?> ComponentParameters =>
        Scenario is null || Template is null
            ? []
            : new Dictionary<string, object?> { [Template.ModelParameterName] = Scenario.Model };

    protected override async Task OnParametersSetAsync()
    {
        Template = Catalog.FindTemplate(TemplateKey);
        if (Template is null)
        {
            return;
        }

        Scenarios = Catalog.GetScenariosForTemplate(Template);
        Scenario = Catalog.FindScenario(Template, ScenarioKey);

        if (Navigation.Uri.EndsWith("/html", StringComparison.OrdinalIgnoreCase))
        {
            Mode = "raw";
        }

        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (Template is null || Scenario is null)
        {
            Html = string.Empty;
            return;
        }

        Html = await HtmlRenderer.RenderHtmlAsync(Template, Scenario);
    }

    private void OnScenarioChanged(ChangeEventArgs args)
    {
        var scenarioKey = args.Value?.ToString();
        Navigation.NavigateTo(PreviewUrl(TemplateKey, scenarioKey));
    }

    private async Task ShowRawHtmlAsync()
    {
        await RefreshAsync();
        if (Scenario is not null)
        {
            Navigation.NavigateTo($"/preview/{TemplateKey}/{Scenario.Key}/html");
        }
    }

    private static string PreviewUrl(string templateKey, string? scenarioKey)
    {
        return string.IsNullOrWhiteSpace(scenarioKey)
            ? $"/preview/{templateKey}"
            : $"/preview/{templateKey}/{scenarioKey}";
    }
}
