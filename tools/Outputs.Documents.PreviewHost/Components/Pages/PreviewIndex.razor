@page "/"
@page "/preview"
@using System.Linq
@using Outputs.Documents.Abstractions
@using Outputs.Documents.Preview.Abstractions
@inject IDocumentPreviewCatalog Catalog

<PageTitle>Document Preview</PageTitle>

<main class="index-page">
    <header class="index-header">
        <div>
            <p class="eyebrow">Razor Document Preview</p>
            <h1>Document Preview</h1>
        </div>
        <a class="quiet-link" href="/preview">Refresh</a>
    </header>

    @if (Catalog.Templates.Count == 0)
    {
        <section class="empty-state">
            <h2>No document templates were discovered.</h2>
            <p>Check that the template assembly is registered, the Razor component has DocumentTemplateAttribute, and the project references the template assembly.</p>
        </section>
    }
    else
    {
        <section class="template-groups">
            @foreach (var group in Catalog.Templates.GroupBy(template => template.Group))
            {
                <section class="template-group">
                    <h2>@group.Key</h2>
                    <div class="template-list">
                        @foreach (var template in group)
                        {
                            <a class="template-row" href="@PreviewUrl(template)">
                                <span>@template.Name</span>
                                <small>@template.ModelType.Name · @GetScenarioCount(template) scenario(s)</small>
                            </a>
                        }
                    </div>
                </section>
            }
        </section>
    }
</main>

@code {
    private string PreviewUrl(DocumentTemplateDescriptor template)
    {
        return PreviewUrl(template.Key, GetFirstScenarioKey(template));
    }

    private int GetScenarioCount(DocumentTemplateDescriptor template)
    {
        return Catalog.GetScenariosForTemplate(template).Count;
    }

    private string? GetFirstScenarioKey(DocumentTemplateDescriptor template)
    {
        return Catalog.GetScenariosForTemplate(template).FirstOrDefault()?.Key;
    }

    private static string PreviewUrl(string templateKey, string? scenarioKey)
    {
        return string.IsNullOrWhiteSpace(scenarioKey)
            ? $"/preview/{templateKey}"
            : $"/preview/{templateKey}/{scenarioKey}";
    }
}
