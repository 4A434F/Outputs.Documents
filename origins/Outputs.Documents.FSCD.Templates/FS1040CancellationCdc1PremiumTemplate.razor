@namespace Outputs.Documents.FSCD.Templates
@using Microsoft.AspNetCore.Components
@using Outputs.Documents.Abstractions
@using Outputs.Documents.FSCD.Contracts
@attribute [DocumentTemplate(
                Key = "fs1040-cdc1-cancellation-letter-premium", 
                Name = "CDC1 Cancellation Letter (FSCD) - Premium", 
                Group = "FSCD")
            ]

<section class="fscd-document">
    <h1>CDC1 Cancellation Letter - Premium</h1>

    <dl>
        <dt>Document identification</dt>
        <dd>@Model.DocumentIdentification</dd>

        <dt>Description</dt>
        <dd>@Model.Description</dd>

        <dt>Primary program</dt>
        <dd>@Model.PrimaryProgram</dd>

        <dt>Layout code</dt>
        <dd>@Model.LayoutCode</dd>
    </dl>
</section>

@code {
    [Parameter]
    public BGOW0044Contract Model { get; set; } = default!;
}
