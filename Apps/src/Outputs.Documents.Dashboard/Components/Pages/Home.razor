@page "/"
@rendermode InteractiveServer

<PageTitle>Outputs Documents Dashboard</PageTitle>

<div class="dashboard-page">
    <section class="page-title-frame">
        <div>
            <p class="eyebrow">Application Shell</p>
            <h2>Outputs Documents Dashboard</h2>
            <p class="page-subtitle">Shared layout for future document tooling interfaces.</p>
        </div>
    </section>

    <section class="empty-shell-panel">
        <span class="material-symbols-outlined" aria-hidden="true">space_dashboard</span>
        <div>
            <h3>Empty dashboard shell</h3>
            <p>Tool pages can be added later without changing the shared layout frame.</p>
        </div>
    </section>
</div>
